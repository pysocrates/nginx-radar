SERVER="user@example-host"
KEY=""
LOG="/var/log/nginx/access.log"
ERROR_LOG="/var/log/nginx/error.log"
FAIL2BAN_LOG="/var/log/fail2ban.log"
FAIL2BAN_CLIENT_PREFIX=""
ENABLE_FAIL2BAN=1
ENABLE_ERROR_LOG=1
ENABLE_UFW=1
ENABLE_SS=1
ENABLE_SYSTEM_METRICS=1
ENABLE_FAIL2BAN_STATUS=1

# Optional local tuning
REFRESH_SECONDS=2
TOP_N=10
BURST_WINDOW_SECONDS=2
BURST_THRESHOLD=10
RECENT_SCANNERS=8
RECENT_ALERTS=8
RECENT_FAIL2BAN=8
RECENT_ERRORS=8
SNAPSHOT_POLL_SECONDS=15
